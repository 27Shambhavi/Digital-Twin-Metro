<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <input>

        <net-file value="../osm/indore.net.xml"/>

        <route-files value="../data/raw/peak_routes.rou.xml"/>

    </input>

    <output>

        <tripinfo-output value="../data/simulation_output/peak_tripinfo.xml"/>

        <summary-output value="../data/simulation_output/peak_summary.xml"/>

        <emission-output value="../data/simulation_output/peak_emission.xml"/>

    </output>

    <time>

        <begin value="0"/>

        <end value="3600"/>

    </time>

</configuration>